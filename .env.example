# ── Database (Supabase Postgres) ─────────────────────────────
# Always keep `sslmode=require` in production so the DB connection is
# TLS-encrypted. Supabase's poolers are not exposed without auth, but require
# TLS explicitly rather than relying on the client default.
# Pooled connection (pgbouncer, port 6543) — used at runtime
DATABASE_URL="postgresql://postgres.<ref>:<db-password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection (port 5432) — used for migrations only
DIRECT_URL="postgresql://postgres.<ref>:<db-password>@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Supabase Auth ────────────────────────────────────────────
# PUBLIC (sent to the browser). Safe to expose ONLY because RLS is enabled
# deny-by-default on every table (packages/db/prisma/rls.sql) and the Supabase
# Data API is left disabled. The anon/publishable key is NOT a secret.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Optional newer alias for the anon key; if set, it takes precedence over
# NEXT_PUBLIC_SUPABASE_ANON_KEY. Same public-safe value.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# SECRET — server-only. Bypasses RLS. Never prefix with NEXT_PUBLIC_ and never
# import into a client component.
SUPABASE_SERVICE_ROLE_KEY=""
# Optional server-only override for the Supabase URL (image storage / auth
# admin). Falls back to NEXT_PUBLIC_SUPABASE_URL when unset.
SUPABASE_URL=""

# ── OpenAI (ChatGPT) ─────────────────────────────────────────
OPENAI_API_KEY=""
# Model used for all agent reasoning (configurable)
OPENAI_MODEL="gpt-4o"
# Image generation model (optional; defaults to gpt-image-1)
OPENAI_IMAGE_MODEL="gpt-image-1"
# Optional LangSmith tracing of every agent call. No-op when unset.
LANGSMITH_API_KEY=""

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Plan ids created in the Razorpay dashboard (INR, monthly)
RAZORPAY_PLAN_PRO=""     # ₹3,999/mo
RAZORPAY_PLAN_SCALE=""   # ₹7,999/mo
# Must be the SAME mode (live/test) as RAZORPAY_KEY_ID above.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ── Worker (Railway) ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Provisioning (Phase 2) ───────────────────────────────────
# Platform GitHub account token (classic PAT with `repo` scope, or
# fine-grained with repo admin) — company repos are created under it.
GITHUB_TOKEN=""
# Vercel personal/team token; the Vercel account needs the GitHub app
# installed so projects can link to the created repos.
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""

# ── Owner emails (Resend) ────────────────────────────────────
# Daily activity reminders + weekly win-back emails to company owners.
# Leave empty to disable all owner emails (dev/staging).
RESEND_API_KEY=""
MAIL_FROM="Adventure AI <hello@adventure-ai.in>"

# ── Misc ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# 32-byte hex key for AES-256-GCM encryption of integration credentials
CREDENTIALS_ENCRYPTION_KEY=""

# ⚠️  DEV/STAGING ONLY. BILLING_TEST_MODE=1 activates trials/subscriptions and
# grants credit packs WITHOUT any Razorpay payment. NEVER set this in
# production — leave it unset/empty. Included here only so its existence is
# documented; do not enable it on a live deployment.
BILLING_TEST_MODE=""
